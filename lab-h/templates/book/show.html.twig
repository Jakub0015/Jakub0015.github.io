{% extends 'base.html.twig' %}

{% block title %}Book{% endblock %}

{% block body %}
    <div class="container my-4">
        <h1 class="mb-4">Book</h1>

        <table class="table table-bordered w-auto">
            <tbody>
            <tr>
                <th class="table-light">Id</th>
                <td>{{ book.id }}</td>
            </tr>
            <tr>
                <th class="table-light">Title</th>
                <td>{{ book.title }}</td>
            </tr>
            <tr>
                <th class="table-light">Author</th>
                <td>{{ book.author }}</td>
            </tr>
            <tr>
                <th class="table-light">Year</th>
                <td>{{ book.year }}</td>
            </tr>
            </tbody>
        </table>

        <a href="{{ path('app_book_index') }}" class="btn btn-secondary">back to list</a>
        <a href="{{ path('app_book_edit', {'id': book.id}) }}" class="btn btn-warning">edit</a>

        {{ include('book/_delete_form.html.twig') }}
    </div>
{% endblock %}
